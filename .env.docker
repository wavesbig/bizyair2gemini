# Docker 部署配置示例
# 复制此文件为 .env 并修改相应值

# ====================
# 基础配置
# ====================

# 应用端口 (默认 3000)
APP_PORT=3000

# 数据持久化目录
DATA_DIR=./data

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ====================
# 数据库
# ====================
# SQLite 数据库路径 (容器内)
# DATABASE_URL=file:/app/data/dev.db

# ====================
# 认证配置
# ====================

# Admin 登录密码
ADMIN_PASSWORD=admin123

# 代理 API Key (必填，用于验证代理请求)
PROXY_API_KEY=sk-your-proxy-api-key-here
